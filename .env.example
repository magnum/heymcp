# --- Auth ---
# Claude Custom Connector (OAuth):
MCP_PUBLIC_URL=https://heymcp.example.com
MCP_OAUTH_USERNAME=admin
MCP_OAUTH_PASSWORD=pick_a_strong_password
# (if MCP_OAUTH_PASSWORD is empty, MCP_AUTH_TOKEN is used as the login password)

# Optional: force oauth | bearer | auto (default auto)
# MCP_AUTH_MODE=oauth

# Static bearer: also accepted when OAuth is enabled (curl / mcp-remote --header)
MCP_AUTH_TOKEN=change_me

# Public Host headers behind Cloudflare / reverse proxy (avoids 421 Invalid Host)
MCP_ALLOWED_HOSTS=heymcp.example.com,localhost,127.0.0.1

# --- Server ---
MCP_TRANSPORT=http
MCP_PORT=8765

# Email send / other mutations (default true in app + compose)
HEY_ALLOW_SEND=true
HEY_ALLOW_WRITE=true

HEY_TIMEOUT=30
HEY_MAX_CHARS=12000
